/* pages/practice/practice.wxss */
.practice-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ===== 顶部状态栏 ===== */
.practice-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: var(--color-bg-card);
  border-bottom: 2rpx solid var(--color-border-light);
}

.header-left, .header-right {
  flex: 0 0 auto;
  min-width: 160rpx;
}

.header-left { text-align: left; }
.header-right { text-align: right; }

.header-center {
  flex: 1;
  text-align: center;
}

.progress-text {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.timer-text {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.wpm-text {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-success);
}

/* ===== 进度条 ===== */
.progress-bar-container {
  height: 6rpx;
  background-color: var(--color-border-light);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary-light), var(--color-primary));
  transition: width 0.3s ease;
}

/* ===== 练习内容区 ===== */
.practice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: var(--spacing-lg) var(--spacing-md);
  gap: var(--spacing-md);
}

/* ===== 单词显示区 ===== */
.word-display-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 24rpx var(--color-shadow);
  position: relative;
  min-height: 400rpx;
}

/* 单词上方音标 */
.word-phonetic {
  margin-bottom: var(--spacing-xs);
}

.word-phonetic .phonetic-text {
  font-size: var(--font-size-xl);
  color: var(--color-text-tertiary);
}

/* 单词上方释义 */
.word-meaning {
  margin-bottom: var(--spacing-md);
}

.word-meaning .meaning-item {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: var(--spacing-xs);
}

.word-text {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6rpx;
  padding: var(--spacing-md);
  transition: opacity 0.3s;
}

.word-text.word-hidden {
  opacity: 0.2;
}

.word-char {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 80rpx;
  font-size: var(--font-size-xxl);
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-secondary);
  border-bottom: 4rpx solid var(--color-border-light);
  background-color: var(--color-bg-tertiary);
  border-radius: var(--radius-sm);
  transition: all 0.15s ease;
}

.word-char.char-current {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
  background-color: var(--color-primary-bg);
  animation: pulse 1s ease-in-out infinite;
}

.word-char.char-correct {
  color: var(--color-success);
  border-bottom-color: var(--color-success);
  background-color: var(--color-success-bg);
}

.word-char.char-error {
  color: var(--color-error);
  border-bottom-color: var(--color-error);
  background-color: var(--color-error-bg);
}

.word-char.char-hidden {
  opacity: 0;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.word-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
}

.placeholder-text {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

.word-actions {
  display: flex;
  gap: var(--spacing-lg);
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 2rpx solid var(--color-border-light);
}

.action-btn {
  padding: 12rpx 32rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background-color: var(--color-bg-tertiary);
  border-radius: var(--radius-full);
  transition: all 0.2s;
}

.action-btn:active {
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
  transform: scale(0.95);
}

/* 翻转模式释义 */
.word-trans-area {
  padding: var(--spacing-lg);
}

.trans-text {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  text-align: center;
}

/* ===== 释义区域（内嵌于单词显示区） ===== */
.meaning-item {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
}

.pos-tag {
  display: inline-flex;
  padding: 2rpx 10rpx;
  font-size: var(--font-size-xl);
  color: var(--color-primary);
  background-color: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.cn-text {
  font-size: var(--font-size-xl);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ===== 完成弹窗 ===== */
.finish-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.finish-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.finish-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  margin: 0 var(--spacing-lg);
  max-width: 600rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

.finish-icon {
  font-size: 80rpx;
}

.finish-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
  width: 100%;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md);
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
}

.stat-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-xs);
}

/* 错词区域 */
.wrong-words-section {
  width: 100%;
}

.section-title {
  font-size: var(--font-size-sm);
  color: var(--color-error);
  font-weight: var(--font-weight-medium);
  display: block;
  margin-bottom: var(--spacing-sm);
}

.wrong-words-list {
  max-height: 240rpx;
  background-color: var(--color-error-bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm);
}

.wrong-word-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--color-error-light);
}

.wrong-word-item:last-child {
  border-bottom: none;
}

.wrong-word {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-error);
}

.wrong-word-trans {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  max-width: 300rpx;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
}

/* 完成操作按钮 */
.finish-actions {
  display: flex;
  gap: var(--spacing-md);
  width: 100%;
  margin-top: var(--spacing-sm);
}

.finish-actions .btn {
  flex: 1;
}

/* ===== 隐藏输入框 ===== */
.hidden-input {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
  z-index: -1;
}
