/* app.wxss - 全局样式与主题变量 */

/* ===== CSS 变量定义 ===== */
page {
  /* 颜色系统 */
  --color-bg: #F5F6FA;
  --color-bg-secondary: #FFFFFF;
  --color-bg-tertiary: #F0F1F5;
  --color-bg-hover: #E8E9ED;
  --color-bg-card: #FFFFFF;
  
  --color-text-primary: #1A1A2E;
  --color-text-secondary: #6B7280;
  --color-text-tertiary: #9CA3AF;
  --color-text-disabled: #D1D5DB;
  
  --color-primary: #4F46E5;
  --color-primary-light: #818CF8;
  --color-primary-dark: #3730A3;
  --color-primary-bg: #EEF2FF;
  
  --color-success: #10B981;
  --color-success-light: #D1FAE5;
  --color-success-bg: #ECFDF5;
  
  --color-error: #EF4444;
  --color-error-light: #FEE2E2;
  --color-error-bg: #FEF2F2;
  
  --color-warning: #F59E0B;
  --color-warning-light: #FEF3C7;
  --color-warning-bg: #FFFBEB;
  
  --color-info: #3B82F6;
  
  --color-border: #E5E7EB;
  --color-border-light: #F3F4F6;
  --color-divider: #F3F4F6;
  
  --color-shadow: rgba(0, 0, 0, 0.08);
  --color-shadow-lg: rgba(0, 0, 0, 0.12);
  
  --color-keyboard-key: #F9FAFB;
  --color-keyboard-key-active: #4F46E5;
  --color-keyboard-text: #1A1A2E;
  
  /* 尺寸 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 999rpx;
  
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 44rpx;
  --font-size-title: 52rpx;
  
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  
  --safe-bottom: env(safe-area-inset-bottom, 0rpx);
  --header-height: 88rpx;
}

/* 暗黑模式 */
@media (prefers-color-scheme: dark) {
  page.theme-dark {
    --color-bg: #0F172A;
    --color-bg-secondary: #1E293B;
    --color-bg-tertiary: #334155;
    --color-bg-hover: #334155;
    --color-bg-card: #1E293B;
    
    --color-text-primary: #F1F5F9;
    --color-text-secondary: #94A3B8;
    --color-text-tertiary: #64748B;
    --color-text-disabled: #475569;
    
    --color-primary: #818CF8;
    --color-primary-light: #A5B4FC;
    --color-primary-dark: #6366F1;
    --color-primary-bg: #1E1B4B;
    
    --color-success: #34D399;
    --color-success-light: #064E3B;
    --color-success-bg: #022C22;
    
    --color-error: #F87171;
    --color-error-light: #7F1D1D;
    --color-error-bg: #1C0B0B;
    
    --color-border: #334155;
    --color-border-light: #1E293B;
    --color-divider: #1E293B;
    
    --color-shadow: rgba(0, 0, 0, 0.3);
    --color-shadow-lg: rgba(0, 0, 0, 0.5);
    
    --color-keyboard-key: #334155;
    --color-keyboard-key-active: #818CF8;
    --color-keyboard-text: #F1F5F9;
  }
}

/* ===== 基础重置 ===== */
page {
  height: 100%;
  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-size-md);
  line-height: 1.6;
}

view, text, image, scroll-view {
  box-sizing: border-box;
}

/* ===== 布局工具类 ===== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-align-center { display: flex; align-items: center; }
.flex-justify-center { display: flex; justify-content: center; }

.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }

/* ===== 间距工具类 ===== */
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.px-sm { padding-left: var(--spacing-sm); padding-right: var(--spacing-sm); }
.px-md { padding-left: var(--spacing-md); padding-right: var(--spacing-md); }
.py-sm { padding-top: var(--spacing-sm); padding-bottom: var(--spacing-sm); }
.py-md { padding-top: var(--spacing-md); padding-bottom: var(--spacing-md); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }

/* ===== 文本工具类 ===== */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }
.text-xs { font-size: var(--font-size-xs); }
.text-sm { font-size: var(--font-size-sm); }
.text-md { font-size: var(--font-size-md); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }
.text-xxl { font-size: var(--font-size-xxl); }
.text-title { font-size: var(--font-size-title); }

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-success { color: var(--color-success); }
.text-error { color: var(--color-error); }
.text-warning { color: var(--color-warning); }

.font-bold { font-weight: var(--font-weight-bold); }
.font-semibold { font-weight: var(--font-weight-semibold); }
.font-medium { font-weight: var(--font-weight-medium); }

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 组件样式 ===== */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: calc(var(--safe-bottom) + 32rpx);
  background-color: var(--color-bg);
}

/* 卡片 */
.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
  margin: var(--spacing-sm) var(--spacing-md);
  overflow: hidden;
}

.card-body {
  padding: var(--spacing-md);
}

.card-header {
  padding: var(--spacing-md);
  border-bottom: 2rpx solid var(--color-border-light);
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  border: none;
  transition: all 0.2s;
}

.btn::after { border: none; }

.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

.btn-primary:active {
  background-color: var(--color-primary-dark);
  transform: scale(0.97);
}

.btn-success {
  background-color: var(--color-success);
  color: #FFFFFF;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--color-border);
  color: var(--color-text-primary);
}

.btn-outline:active {
  background-color: var(--color-bg-tertiary);
}

.btn-sm {
  padding: 8rpx 24rpx;
  font-size: var(--font-size-sm);
}

.btn-lg {
  padding: 20rpx 56rpx;
  font-size: var(--font-size-lg);
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.tag-primary {
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag-success {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.tag-error {
  background-color: var(--color-error-bg);
  color: var(--color-error);
}

.tag-warning {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: var(--color-divider);
  margin: var(--spacing-sm) 0;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.3;
}

.empty-text {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

/* Toast 样式 */
.toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  pointer-events: none;
}

.toast-content {
  background-color: rgba(0, 0, 0, 0.75);
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  max-width: 80vw;
  text-align: center;
  animation: toastIn 0.3s ease;
}

@keyframes toastIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

/* 加载动画 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--spacing-sm);
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-4rpx); }
  20%, 40%, 60%, 80% { transform: translateX(4rpx); }
}

.shake {
  animation: shake 0.4s ease-in-out;
}

/* 弹入动画 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up {
  animation: fadeInUp 0.3s ease-out;
}

/* 淡入动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 安全区域底部 */
.safe-bottom {
  padding-bottom: var(--safe-bottom);
}
